CONTACT_TO_EMAIL=bbeyzaayigitt@gmail.com

# ============================================================
# RESEND (production / Render) — RESEND_API_KEY doluysa kullanilir
# https://resend.com/api-keys
# Yerelde Gmail SMTP kullanacaksaniz RESEND_API_KEY bos birakin.
# ============================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=CYCLION İletişim <onboarding@resend.dev>

# ============================================================
# GMAIL SMTP (yerel gelistirme) — Render free tier SMTP engeller
# ============================================================
