SMTP_TIMEOUT=20
SMTP_USER=bbeyzaayigitt@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_NAME=CYCLION İletişim

# ============================================================
# CORS — production'da Vercel URL'nizi ekleyin
# Ornek: https://faradai-cyclion.vercel.app,http://localhost:3000
